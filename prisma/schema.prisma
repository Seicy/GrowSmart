generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model config {
  id             Int      @id @default(autoincrement())
  soilThreshold  Int      @default(30)
  manualWatering Boolean  @default(false)
  updatedAt      DateTime
}

model log {
  id        Int      @id @default(autoincrement())
  type      String
  title     String
  message   String
  createdAt DateTime @default(now())
}

model plant {
  id         Int          @id @default(autoincrement())
  name       String
  type       String
  createdAt  DateTime     @default(now())
  sensordata sensordata[]
}

model sensordata {
  id             Int      @id @default(autoincrement())
  temperature    Float
  humidity       Float
  soilMoisture   Float
  createdAt      DateTime @default(now())
  plantId        Int
  motionDetected Boolean  @default(false)
  plant          plant    @relation(fields: [plantId], references: [id], map: "SensorData_plantId_fkey")

  @@index([plantId], map: "SensorData_plantId_fkey")
}

model user {
  id        Int      @id @default(autoincrement())
  email     String   @unique(map: "User_email_key")
  password  String
  createdAt DateTime @default(now())
  name      String   @default("User")
}
